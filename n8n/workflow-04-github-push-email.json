      "main": [[{ "node": "SHAをマージ", "type": "main", "index": 0 }]]
    },
    "SHAをマージ": {
      "main": [[{ "node": "GitHub: 記事をコミット", "type": "main", "index": 0 }]]
    },
    "GitHub: 記事をコミット": {
      "main": [[
        { "node": "Beehiiv: メール配信予約", "type": "main", "index": 0 },
        { "node": "X (Twitter): 自動投稿", "type": "main", "index": 0 }
      ]]
    },
    "Beehiiv: メール配信予約": {
      "main": [[{ "node": "完了ログ", "type": "main", "index": 0 }]]
    },
    "X (Twitter): 自動投稿": {
      "main": [[{ "node": "完了ログ", "type": "main", "index": 0 }]]
    }
  },
