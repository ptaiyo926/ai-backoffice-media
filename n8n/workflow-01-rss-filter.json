          "waitForSubWorkflow": true
        }
      },
      "id": "node-01-11",
      "name": "→ WF02: 記事生成",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.1,
      "position": [2000, 460]
    }
